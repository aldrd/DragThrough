    <s:String x:Key="tray_exit">退出</s:String>
    <s:String x:Key="tray_tooltip">DragThrough</s:String>

    <!-- Feedback form -->
    <s:String x:Key="feedback_title">反馈</s:String>
    <s:String x:Key="feedback_prompt">请描述问题或建议。可以附加屏幕截图。</s:String>
    <s:String x:Key="feedback_screenshots">屏幕截图：</s:String>
    <s:String x:Key="feedback_add_file">添加文件...</s:String>
