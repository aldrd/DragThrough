<UserControl x:Class="ZombieBar.Controls.TaskButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ZombieBar.Converters"
             Loaded="TaskButton_OnLoaded"
             Unloaded="TaskButton_OnUnloaded">
    <UserControl.Resources>
        <converters:TaskButtonTextConverter x:Key="TaskButtonTextConverter"/>
        <converters:TaskButtonTrimVisibilityConverter x:Key="TaskButtonTrimVisibilityConverter"/>
    </UserControl.Resources>
    <Button Name="AppButton"
            ToolTip="{Binding Path=Title}"
            Click="AppButton_OnClick"
            MouseUp="AppButton_OnMouseUp"
            PreviewMouseDown="AppButton_OnPreviewMouseDown"
            ContextMenuOpening="AppButton_OnContextMenuOpening"
            DragEnter="AppButton_OnDragEnter"
            DragLeave="AppButton_OnDragLeave">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Image Source="{Binding Path=Icon, Mode=OneWay}"
                   Grid.Column="0"
                   Style="{DynamicResource TaskIcon}" />
            <!-- Start-trimming label: keeps the beginning of the text. -->
            <Label Grid.Column="1"
                       x:Name="LeftLabel"
                       Style="{DynamicResource LeftTaskButtonLabelStyle}">
                <Label.Visibility>
                    <MultiBinding Converter="{StaticResource TaskButtonTrimVisibilityConverter}" ConverterParameter="Start">
                        <Binding Path="Title" />
                        <Binding />
                    </MultiBinding>
                </Label.Visibility>
                <Label.Content>
                    <MultiBinding Converter="{StaticResource TaskButtonTextConverter}">
                        <Binding Path="Title" />
                        <Binding />
                    </MultiBinding>
                </Label.Content>
            </Label>
            <!-- End-trimming label: keeps the end of the text (e.g. the deepest folder of a path). -->
            <Label Grid.Column="1"
                       x:Name="RightLabel"
                       Style="{DynamicResource RightTaskButtonLabelStyle}">
                <Label.Visibility>
                    <MultiBinding Converter="{StaticResource TaskButtonTrimVisibilityConverter}" ConverterParameter="End">
                        <Binding Path="Title" />
                        <Binding />
                    </MultiBinding>
                </Label.Visibility>
                <Label.Content>
                    <MultiBinding Converter="{StaticResource TaskButtonTextConverter}">
                        <Binding Path="Title" />
                        <Binding />
                    </MultiBinding>
                </Label.Content>
            </Label>
        </Grid>
        <Button.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{DynamicResource restore}" 
                          Click="RestoreMenuItem_OnClick" 
                          Name="RestoreMenuItem">
                    <MenuItem.Icon>
                        <TextBlock FontFamily="Marlett" 
                                   Text="&#x32;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource move}" 
                          Click="MoveMenuItem_OnClick"  
                          Name="MoveMenuItem" />
                <MenuItem Header="{DynamicResource size}" 
                          Click="SizeMenuItem_OnClick"  
                          Name="SizeMenuItem" />
                <MenuItem Header="{DynamicResource minimize}" 
                          Click="MinimizeMenuItem_OnClick" 
                          Name="MinimizeMenuItem">
                    <MenuItem.Icon>
                        <TextBlock FontFamily="Marlett" 
                                   Text="&#x30;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource maximize}" 
                          Click="MaximizeMenuItem_OnClick" 
                          Name="MaximizeMenuItem">
                    <MenuItem.Icon>
                        <TextBlock FontFamily="Marlett" 
                                   Text="&#x31;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="{DynamicResource close}" 
                          FontWeight="Bold"
                          Click="CloseMenuItem_OnClick">
                    <MenuItem.Icon>
                        <TextBlock FontFamily="Marlett" 
                                   Text="&#x72;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Button.ContextMenu>
    </Button>
</UserControl>
