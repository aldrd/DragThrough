<Window x:Class="ZombieBar.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource about_title}"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <StackPanel Margin="20">
        <TextBlock Text="{DynamicResource tray_tooltip}"
                   FontSize="22"
                   FontWeight="SemiBold" />

        <TextBlock x:Name="VersionText"
                   Foreground="Gray"
                   Margin="0,2,0,0" />

        <TextBlock Text="{DynamicResource about_tagline}"
                   TextWrapping="Wrap"
                   Margin="0,12,0,0" />

        <TextBlock x:Name="UpdateStatus"
                   Foreground="Gray"
                   TextWrapping="Wrap"
                   Margin="0,14,0,0"
                   Visibility="Collapsed" />

        <StackPanel Orientation="Horizontal"
                    Margin="0,18,0,0">
            <Button x:Name="CoffeeButton"
                    Content="{DynamicResource tray_buy_coffee}"
                    Click="Coffee_OnClick"
                    Padding="12,5"
                    Margin="0,0,8,0" />
            <Button x:Name="CheckUpdatesButton"
                    Content="{DynamicResource about_check_updates}"
                    Click="CheckUpdates_OnClick"
                    Padding="12,5" />
        </StackPanel>

        <Button x:Name="CloseButton"
                Content="{DynamicResource about_close}"
                IsCancel="True"
                IsDefault="True"
                Click="Close_OnClick"
                HorizontalAlignment="Right"
                MinWidth="92"
                Padding="12,5"
                Margin="0,20,0,0" />
    </StackPanel>
</Window>
