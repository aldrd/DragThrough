<Window x:Class="ZombieBar.FeedbackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource feedback_title}"
        Width="540"
        Height="560"
        MinWidth="440"
        MinHeight="440"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource feedback_prompt}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />

        <TextBox Grid.Row="1"
                 x:Name="DescriptionBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 SpellCheck.IsEnabled="True"
                 MinHeight="150"
                 Padding="5" />

        <DockPanel Grid.Row="2"
                   Margin="0,10,0,4">
            <TextBlock Text="{DynamicResource feedback_screenshots}"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                <Button x:Name="AddFileButton"
                        Content="{DynamicResource feedback_add_file}"
                        Click="AddFile_OnClick"
                        Padding="10,3"
                        Margin="6,0,0,0" />
                <Button x:Name="CaptureButton"
                        Content="{DynamicResource feedback_capture}"
                        Click="Capture_OnClick"
                        Padding="10,3"
                        Margin="6,0,0,0" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="3"
              MinHeight="90"
              MaxHeight="170"
              Margin="0,0,0,4">
            <Border BorderBrush="#FFBDBDBD"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="AttachmentsList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="5">
                                    <Border BorderBrush="#FFBDBDBD"
                                            BorderThickness="1"
                                            Background="#11000000"
                                            Width="104"
                                            Height="72">
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="Uniform"
                                               Margin="3" />
                                    </Border>
                                    <Button Content="✕"
                                            Width="18"
                                            Height="18"
                                            Padding="0"
                                            FontSize="10"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,-6,-6,0"
                                            Click="RemoveAttachment_OnClick"
                                            Tag="{Binding}"
                                            ToolTip="{DynamicResource feedback_remove}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            <TextBlock x:Name="NoShotsHint"
                       Text="{DynamicResource feedback_no_screenshots}"
                       Foreground="Gray"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False" />
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="SendButton"
                    Content="{DynamicResource feedback_send}"
                    IsDefault="True"
                    Click="Send_OnClick"
                    MinWidth="92"
                    Padding="12,5"
                    Margin="0,0,8,0" />
            <Button x:Name="CancelButton"
                    Content="{DynamicResource feedback_cancel}"
                    IsCancel="True"
                    Click="Cancel_OnClick"
                    MinWidth="92"
                    Padding="12,5" />
        </StackPanel>
    </Grid>
</Window>
