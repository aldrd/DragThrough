<UserControl x:Class="ZombieBar.Controls.TaskButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ZombieBar.Converters"
             xmlns:local="clr-namespace:ZombieBar.Controls"
             Loaded="TaskButton_OnLoaded"
             Unloaded="TaskButton_OnUnloaded">
    <UserControl.Resources>
        <converters:TaskButtonTextConverter x:Key="TaskButtonTextConverter"/>
        <converters:TaskButtonTrimVisibilityConverter x:Key="TaskButtonTrimVisibilityConverter"/>
        <converters:MinWidthVisibilityConverter x:Key="MinWidthVisibilityConverter"/>
        <converters:CompactCloseVisibilityConverter x:Key="CompactCloseVisibilityConverter"/>
    </UserControl.Resources>
    <Button Name="AppButton"
            ToolTip="{Binding Path=FullTitle}"
            Click="AppButton_OnClick"
            MouseUp="AppButton_OnMouseUp"
            PreviewMouseDown="AppButton_OnPreviewMouseDown"
            ContextMenuOpening="AppButton_OnContextMenuOpening"
            DragEnter="AppButton_OnDragEnter"
            DragLeave="AppButton_OnDragLeave">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image Source="{Binding Path=Icon, Mode=OneWay}"
                   Grid.Column="0"
                   Style="{DynamicResource TaskIcon}" />
            <!-- Title labels. Collapsed in compact mode (x:Name so the code-behind can toggle it),
                 which leaves just the icon and the close button. -->
            <Grid Grid.Column="1" x:Name="LabelHost">
                <!-- Start-trimming label: keeps the beginning of the text. -->
                <Label x:Name="LeftLabel"
                           Style="{DynamicResource LeftTaskButtonLabelStyle}">
                    <Label.Visibility>
                        <MultiBinding Converter="{StaticResource TaskButtonTrimVisibilityConverter}" ConverterParameter="Start">
                            <Binding Path="Title" />
                            <Binding />
                        </MultiBinding>
                    </Label.Visibility>
                    <Label.Content>
                        <MultiBinding Converter="{StaticResource TaskButtonTextConverter}">
                            <Binding Path="Title" />
                            <Binding />
                        </MultiBinding>
                    </Label.Content>
                </Label>
                <!-- End-trimming label: keeps the end of the text (e.g. the deepest folder of a path). -->
                <Label x:Name="RightLabel"
                           Style="{DynamicResource RightTaskButtonLabelStyle}">
                    <Label.Visibility>
                        <MultiBinding Converter="{StaticResource TaskButtonTrimVisibilityConverter}" ConverterParameter="End">
                            <Binding Path="Title" />
                            <Binding />
                        </MultiBinding>
                    </Label.Visibility>
                    <Label.Content>
                        <MultiBinding Converter="{StaticResource TaskButtonTextConverter}">
                            <Binding Path="Title" />
                            <Binding />
                        </MultiBinding>
                    </Label.Content>
                </Label>
            </Grid>
            <!-- Close (X) button, styled like the main taskbar's window-close button (red on hover).
                 Shown when the button is compact (icon + close) or wide enough to fit it. -->
            <Button x:Name="CloseButton"
                    Grid.Column="2"
                    Style="{DynamicResource TaskButtonCloseButton}"
                    Click="CloseButton_OnClick">
                <Button.Visibility>
                    <MultiBinding Converter="{StaticResource CompactCloseVisibilityConverter}" ConverterParameter="90">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType={x:Type local:TaskButton}}" />
                        <Binding Path="IsCompact" RelativeSource="{RelativeSource AncestorType={x:Type local:TaskButton}}" />
                    </MultiBinding>
                </Button.Visibility>
            </Button>
        </Grid>
        <Button.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{DynamicResource restore}" 
                          Click="RestoreMenuItem_OnClick" 
                          Name="RestoreMenuItem">
                    <MenuItem.Icon>
                        <TextBlock FontFamily="Marlett" 
                                   Text="&#x32;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource move}" 
                          Click="MoveMenuItem_OnClick"  
                          Name="MoveMenuItem" />
                <MenuItem Header="{DynamicResource size}" 
                          Click="SizeMenuItem_OnClick"  
                          Name="SizeMenuItem" />
                <MenuItem Header="{DynamicResource minimize}" 
                          Click="MinimizeMenuItem_OnClick" 
                          Name="MinimizeMenuItem">
                    <MenuItem.Icon>
                        <TextBlock FontFamily="Marlett" 
                                   Text="&#x30;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource maximize}" 
                          Click="MaximizeMenuItem_OnClick" 
                          Name="MaximizeMenuItem">
                    <MenuItem.Icon>
                        <TextBlock FontFamily="Marlett" 
                                   Text="&#x31;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="{DynamicResource close}" 
                          FontWeight="Bold"
                          Click="CloseMenuItem_OnClick">
                    <MenuItem.Icon>
                        <TextBlock FontFamily="Marlett" 
                                   Text="&#x72;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Button.ContextMenu>
    </Button>
</UserControl>
