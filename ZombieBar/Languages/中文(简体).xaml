    <s:String x:Key="feedback_cancel">取消</s:String>
    <s:String x:Key="feedback_empty">请描述问题或建议。</s:String>
    <s:String x:Key="feedback_screenshot_hint">将截图从打开的文件夹拖到 GitHub issue 中，然后提交。</s:String>
    <s:String x:Key="feedback_clipboard_hint">文本已复制到剪贴板——请在 issue 中粘贴（Ctrl+V）。</s:String>
    <s:String x:Key="feedback_body_screenshots">_在此附加截图（从打开的文件夹中拖入）。_</s:String>
    <s:String x:Key="feedback_image_filter">图像</s:String>
    <s:String x:Key="feedback_all_files">所有文件</s:String>

    <!-- Share the app -->
    <s:String x:Key="share_app">分享应用</s:String>
    <s:String x:Key="share_copy_link">复制链接</s:String>
    <s:String x:Key="share_tweet">发推 (X)</s:String>
    <s:String x:Key="share_telegram">分享到 Telegram</s:String>
    <s:String x:Key="share_email">电子邮件</s:String>
    <s:String x:Key="share_link_copied">链接已复制到剪贴板</s:String>
    <s:String x:Key="share_text">ZombieBar — Windows 11 任务栏替代工具</s:String>

    <s:String x:Key="restore">恢复(_R)</s:String>
    <s:String x:Key="move">移动(_M)</s:String>
    <s:String x:Key="size">大小(_S)</s:String>
    <s:String x:Key="minimize">最小化(_N)</s:String>
    <s:String x:Key="maximize">最大化(_X)</s:String>
    <s:String x:Key="close">关闭(_C)</s:String>

    <s:String x:Key="show_hidden">显示隐藏的图标</s:String>
    <s:String x:Key="hide">隐藏</s:String>

    <s:String x:Key="set_time">调整日期/时间(_A)</s:String>

    <s:String x:Key="open_folder">&amp;打开文件夹</s:String>
