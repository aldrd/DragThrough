<Window x:Class="ZombieBar.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <!-- Slim rounded progress bar. -->
        <Style x:Key="Bar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="{DynamicResource TrackBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}" ClipToBounds="True">
                            <Grid>
                                <Border x:Name="PART_Track" />
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        CornerRadius="4"
                                        Background="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Width="380"
            Margin="16"
            CornerRadius="10"
            Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.30" Color="Black" />
        </Border.Effect>

        <StackPanel Margin="20">
            <!-- Header -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0"
                       x:Name="AppIcon"
                       Width="24" Height="24"
                       Margin="0,0,10,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Grid.Column="1"
                           Text="{DynamicResource update_title}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource FgBrush}" />
                <TextBlock Grid.Column="2"
                           x:Name="VersionText"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource SubFgBrush}" />
            </Grid>

            <TextBlock x:Name="StatusText"
                       Text="{DynamicResource update_downloading}"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource FgBrush}" />

            <ProgressBar x:Name="Bar" Style="{StaticResource Bar}" />

            <TextBlock x:Name="DetailText"
                       Margin="0,8,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource SubFgBrush}" />

            <Button x:Name="CancelButton"
                    Content="{DynamicResource feedback_cancel}"
                    Style="{StaticResource DialogButton}"
                    Click="Cancel_OnClick"
                    HorizontalAlignment="Right"
                    MinWidth="92"
                    Margin="0,16,0,0" />
        </StackPanel>
    </Border>
</Window>
