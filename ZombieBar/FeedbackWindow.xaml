<Window x:Class="ZombieBar.FeedbackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource feedback_title}"
        Width="560"
        Height="620"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">
    <Border Margin="16"
            CornerRadius="10"
            Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.30" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar (draggable). -->
            <Grid Grid.Row="0" Margin="18,12,10,0" Background="Transparent" MouseLeftButtonDown="Header_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0"
                       x:Name="AppIcon"
                       Width="20" Height="20"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Grid.Column="1"
                           Text="{DynamicResource feedback_title}"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource FgBrush}" />
                <Button Grid.Column="2"
                        Style="{StaticResource DialogCloseButton}"
                        Click="Cancel_OnClick" />
            </Grid>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="18,10,18,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{DynamicResource feedback_prompt}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource FgBrush}"
                           Margin="0,0,0,8" />

                <TextBox Grid.Row="1"
                         x:Name="DescriptionBox"
                         Style="{StaticResource DialogTextBox}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         SpellCheck.IsEnabled="True"
                         MinHeight="150" />

                <DockPanel Grid.Row="2" Margin="0,10,0,4">
                    <TextBlock Text="{DynamicResource feedback_screenshots}"
                               Foreground="{DynamicResource FgBrush}"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right">
                        <Button x:Name="AddFileButton"
                                Style="{StaticResource DialogButton}"
                                Content="{DynamicResource feedback_add_file}"
                                Click="AddFile_OnClick"
                                Margin="6,0,0,0" />
                        <Button x:Name="CaptureButton"
                                Style="{StaticResource DialogButton}"
                                Content="{DynamicResource feedback_capture}"
                                Click="Capture_OnClick"
                                Margin="6,0,0,0" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="3"
                      MinHeight="90"
                      MaxHeight="170"
                      Margin="0,0,0,4">
                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="{DynamicResource ControlBgBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="3">
                            <ItemsControl x:Name="AttachmentsList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="5">
                                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Background="#11000000"
                                                    Width="104"
                                                    Height="72">
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="Uniform"
                                                       Margin="3" />
                                            </Border>
                                            <Button Style="{StaticResource DialogCloseButton}"
                                                    Width="18"
                                                    Height="18"
                                                    FontSize="9"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,-6,-6,0"
                                                    Click="RemoveAttachment_OnClick"
                                                    Tag="{Binding}"
                                                    ToolTip="{DynamicResource feedback_remove}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <TextBlock x:Name="NoShotsHint"
                               Text="{DynamicResource feedback_no_screenshots}"
                               Foreground="{DynamicResource SubFgBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False" />
                </Grid>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,12,0,0">
                    <Button x:Name="SendButton"
                            Style="{StaticResource DialogPrimaryButton}"
                            Content="{DynamicResource feedback_send}"
                            IsDefault="True"
                            Click="Send_OnClick"
                            Margin="0,0,8,0" />
                    <Button x:Name="CancelButton"
                            Style="{StaticResource DialogButton}"
                            Content="{DynamicResource feedback_cancel}"
                            IsCancel="True"
                            Click="Cancel_OnClick" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
